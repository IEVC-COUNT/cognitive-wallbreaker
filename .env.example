# 认知破壁机 V2.0 环境变量配置
# 复制此文件为 .env 并填写实际值

# ═══ OpenAI 兼容 API（必填） ═══
# DeepSeek 或其他 OpenAI 兼容的 API 密钥
OPENAI_API_KEY=sk-你的API密钥

# API 地址（DeepSeek 官方: https://api.deepseek.com/v1）
# 或者本地代理: http://127.0.0.1:4000/v1
OPENAI_BASE_URL=http://127.0.0.1:4000/v1

# ═══ 模型选择（可选） ═══
# deepseek-v4-flash（快速）或 deepseek-v4-pro（强推理）
WALLBREAKER_MODEL=deepseek-v4-flash

# ═══ Telegram Bot（可选） ═══
# 不需要 Bot 功能可不填
TELEGRAM_BOT_TOKEN=

# ═══ Mem0 记忆系统（可选） ═══
# 需要 Qdrant 向量数据库支持
QDRANT_HOST=
QDRANT_PORT=6333
